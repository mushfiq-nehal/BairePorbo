# NVIDIA NIM (used for embeddings + admin parse/enrich helpers)
NVIDIA_API_KEY=your_nim_api_key
NIM_MODEL=google/gemma-4-31b-it
NIM_FALLBACK_MODEL=
NIM_MODEL_LABEL=
NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NIM_EMBEDDING_URL=https://integrate.api.nvidia.com/v1/embeddings

# OpenRouter (used for the user-facing chat / mentor)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_FALLBACK_MODEL=mistralai/ministral-3b-2512
# Optional attribution headers (recommended)
OPENROUTER_SITE_URL=https://baireporbo.com
OPENROUTER_APP_NAME=BairePorbo

# Prompt cache (Postgres-backed; off by default to disable, on by default otherwise)
PROMPT_CACHE_TTL_HOURS=24
PROMPT_CACHE_DISABLED=

# Redis (rate limiting)
REDIS_URL=
REDIS_PREFIX=bp

# ── Neon (replaces Supabase PostgreSQL) ─────────────────────────────────────
# Get this from the Neon console → your project → Connection string
DATABASE_URL=postgresql://username:password@hostname/database?sslmode=require

# ── Clerk (replaces Supabase Auth) ──────────────────────────────────────────
# Create an app at https://clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Webhook secret — set after creating a webhook endpoint in the Clerk dashboard
# pointing to: https://yourdomain.com/api/webhooks/clerk  (event: user.created)
CLERK_WEBHOOK_SECRET=whsec_xxx
# Optional: override default Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Cloudflare R2 (replaces Supabase Storage) ────────────────────────────────
# Get these from: Cloudflare Dashboard → R2 → your bucket → API tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=baireporbo-assets
# Public domain for the bucket (set under R2 bucket → Settings → Public Access)
# e.g. cdn.baireporbo.com  or  pub-xxx.r2.dev
NEXT_PUBLIC_R2_PUBLIC_DOMAIN=cdn.baireporbo.com
