{
  "expo": {
    "name": "BairePorbo",
    "slug": "baireporbo",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "baireporbo",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.baireporbo.ios"
    },
    "android": {
      "package": "app.baireporbo.android",
      "blockedPermissions": ["android.permission.SYSTEM_ALERT_WINDOW"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#f8f8f7"
        }
      ],
      "expo-background-task",
      [
        "expo-notifications",
        {
          "color": "#0f8f8d",
          "defaultChannel": "content"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBase": "https://www.baireporbo.app"
    }
  }
}
