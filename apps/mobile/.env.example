# Public env vars are inlined by Metro at build time (EXPO_PUBLIC_ prefix).
# Copy to .env.local and fill in. The Clerk key is the SAME publishable key the
# web app uses (NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY).

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# API base — production Vercel deployment. Point at a preview URL for staging.
# Use the canonical www host — the apex (baireporbo.app) 301-redirects to www,
# and a 301 turns POST into GET, which breaks every write/chat endpoint (405).
EXPO_PUBLIC_API_BASE=https://www.baireporbo.app
